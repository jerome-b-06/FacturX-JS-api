# ============================================
# FacturX-JS-api Environment Configuration
# ============================================
# Copy this file to .env and fill in your actual values

# ============================================
# Database Configuration
# ============================================
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://postgres:password@localhost:5432/facturx_db

# ============================================
# Application Environment
# ============================================
# Environment mode: development, production, or test
NODE_ENV=development

# Server port
PORT=5000

# ============================================
# CORS Configuration
# ============================================
# Comma-separated list of allowed origins for CORS
# Example: http://localhost:3000,http://localhost:5173,https://app.example.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5000

# ============================================
# PDF Generation Settings (Optional)
# ============================================
# Run Puppeteer in headless mode (true/false)
PDF_HEADLESS=true

# Scale factor for PDF rendering (0.5 to 2)
PDF_SCALE=1

# PDF margin settings (in inches)
PDF_MARGIN_TOP=0.5
PDF_MARGIN_BOTTOM=0.5
PDF_MARGIN_LEFT=0.5
PDF_MARGIN_RIGHT=0.5

# PDF format: Letter, A4, A3, etc.
PDF_FORMAT=A4

# ============================================
# Application Logging
# ============================================
# Log level: error, warn, info, debug, trace
LOG_LEVEL=info

# ============================================
# Email Configuration (Future Use)
# ============================================
# SMTP server host
# SMTP_HOST=smtp.example.com

# SMTP server port
# SMTP_PORT=587

# SMTP username
# SMTP_USER=your-email@example.com

# SMTP password
# SMTP_PASS=your-password

# Sender email address
# MAIL_FROM=noreply@facturx-api.com

# ============================================
# API Configuration
# ============================================
# API base URL (for generating absolute URLs in documents)
API_BASE_URL=http://localhost:5000

# ============================================
# Security Settings (Future Use)
# ============================================
# JWT secret key for authentication
# JWT_SECRET=your-super-secret-key-change-in-production

# JWT token expiration (in hours)
# JWT_EXPIRATION=24

# ============================================
# Feature Flags (Future Use)
# ============================================
# Enable test data seeding on startup
# SEED_DATABASE=true

# Enable API documentation
# ENABLE_SWAGGER=true

# ============================================
# Third-party Services (Future Use)
# ============================================
# Stripe API key for payment processing
# STRIPE_KEY=pk_test_...

# SendGrid API key for email
# SENDGRID_API_KEY=SG.xxx

# AWS S3 configuration for document storage
# AWS_S3_BUCKET=facturx-storage
# AWS_S3_REGION=eu-west-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ============================================
# Monitoring & Analytics (Future Use)
# ============================================
# Sentry DSN for error tracking
# SENTRY_DSN=https://xxx@sentry.io/xxx

# Google Analytics tracking ID
# ANALYTICS_TRACKING_ID=UA-xxx

# ============================================
# Notes
# ============================================
# - Never commit the .env file to version control
# - Keep .env.example updated as new variables are added
# - Use strong, random values for secrets in production
# - Restart the application after changing environment variables

